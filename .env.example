NODE_ENV=development

ASTRIX_IMAGE=astrix:local
GATEWAY_PORT=8333
ASTRIX_HOST=astrix.example.com
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

APP_HOST=0.0.0.0
APP_PORT=3001
APP_PUBLIC_API_URL=

API_HOST=0.0.0.0
API_PORT=3000
API_LOG_LEVEL=info
CORS_ORIGIN=http://127.0.0.1:8333

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=astrix
POSTGRES_USER=astrix
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://astrix:change-me@localhost:5432/astrix

REDIS_HOST=redis
REDIS_PORT=6579
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@localhost:6579

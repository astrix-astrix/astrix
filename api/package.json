{
  "name": "@astrix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:migrate": "tsx ./node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "db:rollback": "tsx ./node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "redis": "^5.10.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.17.0 <25"
  }
}
